{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": ["*.ts", "src/commoncrawl.ts", "src/http.ts", "src/main.ts", "src/splitter.ts", "src/types.ts", "src/warc.ts"],
  "exclude": ["node_modules", "dist", "data"]
}
